{
  "elements": [
    {
      "type": "Label",
      "caption": "Persistence test UI for Module 3 mockup – self-routing import stage"
    },
    {
      "type": "SelectInstance",
      "name": "Module1InstanceID",
      "caption": "Module 1 Instance"
    },
    {
      "type": "SelectInstance",
      "name": "Module2InstanceID",
      "caption": "Module 2 Instance"
    },
    {
      "type": "SelectInstance",
      "name": "VaultInstanceID",
      "caption": "Vault Instance"
    },
    {
      "type": "ValidationTextBox",
      "name": "ImportedModule1ConfigJson",
      "caption": "Imported Module 1 Config JSON"
    },
    {
      "type": "Label",
      "caption": "This Module 3 instance automatically uses its own InstanceID to find matching GroupDispatch routes in the imported Module 1 configuration."
    },
    {
      "type": "List",
      "name": "GroupStateMappings",
      "caption": "Group → State → Output Mapping",
      "rowCount": 12,
      "add": false,
      "delete": false,
      "sort": {
        "column": "GroupName",
        "direction": "ascending"
      },
      "columns": [
        {
          "name": "Enabled",
          "caption": "On",
          "width": "50px",
          "add": false,
          "edit": {
            "type": "CheckBox"
          }
        },
        {
          "name": "GroupName",
          "caption": "Module 1 Group",
          "width": "180px",
          "add": "",
          "edit": {
            "type": "ValidationTextBox"
          }
        },
        {
          "name": "HouseState",
          "caption": "House State",
          "width": "160px",
          "add": "0",
          "edit": {
            "type": "Select",
            "options": []
          }
        },
        {
          "name": "AssignedOutputs",
          "caption": "Assigned Outputs",
          "width": "260px",
          "add": "",
          "edit": {
            "type": "ValidationTextBox"
          }
        },
        {
          "name": "MinSeconds",
          "caption": "Min Sec",
          "width": "90px",
          "add": 60,
          "edit": {
            "type": "NumberSpinner"
          }
        }
      ],
      "values": []
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Read Module 1 Configuration",
      "onClick": "ARMM_ReadModule1Configuration($id);"
    },
    {
      "type": "Button",
      "caption": "Build Rows From My Module 1 Routing",
      "onClick": "ARMM_BuildRowsFromMyRouting($id);"
    },
    {
      "type": "Label",
      "caption": "Read first, then build rows. Row generation uses this Module 3 instance ID and GroupDispatch entries from the imported Module 1 configuration."
    }
  ],
  "status": [
    {
      "code": 101,
      "icon": "inactive",
      "caption": "Creating instance"
    },
    {
      "code": 102,
      "icon": "active",
      "caption": "Instance is active"
    },
    {
      "code": 104,
      "icon": "inactive",
      "caption": "Instance is inactive"
    },
    {
      "code": 200,
      "icon": "error",
      "caption": "Module 1 read failed"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "No routing found for this Module 3 instance in imported Module 1 GroupDispatch"
    },
    {
      "code": 202,
      "icon": "active",
      "caption": "Module 1 configuration imported"
    },
    {
      "code": 203,
      "icon": "active",
      "caption": "Rows built from this Module 3 routing"
    }
  ]
}