  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Read Module 1 Configuration",
      "onClick": "IPS_RequestAction($id, \"ReadModule1Configuration\", true);"
    },
    {
      "type": "Button",
      "caption": "Build Rows From My Module 1 Routing",
      "onClick": "IPS_RequestAction($id, \"BuildRowsFromMyRouting\", true);"
    },
    {
      "type": "Button",
      "caption": "Load Selected Rule Into Editor",
      "onClick": [
        "IPS_SetProperty($id, 'EditorRuleID', (string) $GroupStateMappings['RuleID']);",
        "IPS_SetProperty($id, 'EditorEnabled', (bool) $GroupStateMappings['Enabled']);",
        "IPS_SetProperty($id, 'EditorGroupIDs', json_encode($GroupStateMappings['GroupIDs'] ?? []));",
        "IPS_SetProperty($id, 'EditorHouseState', (string) $GroupStateMappings['HouseState']);",
        "IPS_SetProperty($id, 'EditorSeverity', (string) $GroupStateMappings['Severity']);",
        "IPS_SetProperty($id, 'EditorBypassThrottle', (bool) $GroupStateMappings['BypassThrottle']);",
        "IPS_SetProperty($id, 'EditorOutputResourceIDs', json_encode($GroupStateMappings['OutputResourceIDs'] ?? []));",
        "IPS_ApplyChanges($id);"
      ]
    },
    {
      "type": "Button",
      "caption": "Apply Editor To Selected Rule",
      "onClick": [
        "$rows = json_decode(IPS_GetProperty($id, 'GroupStateMappings'), true);",
        "$editorRuleID = (string) IPS_GetProperty($id, 'EditorRuleID');",
        "$editorEnabled = (bool) IPS_GetProperty($id, 'EditorEnabled');",
        "$editorGroupIDs = json_decode((string) IPS_GetProperty($id, 'EditorGroupIDs'), true);",
        "$editorHouseState = (string) IPS_GetProperty($id, 'EditorHouseState');",
        "$editorSeverity = (string) IPS_GetProperty($id, 'EditorSeverity');",
        "$editorBypassThrottle = (bool) IPS_GetProperty($id, 'EditorBypassThrottle');",
        "$editorOutputIDs = json_decode((string) IPS_GetProperty($id, 'EditorOutputResourceIDs'), true);",
        "if (!is_array($rows)) { $rows = []; }",
        "foreach ($rows as &$row) {",
        "    if (((string) ($row['RuleID'] ?? '')) !== $editorRuleID) {",
        "        continue;",
        "    }",
        "    $row['Enabled'] = $editorEnabled;",
        "    $row['GroupIDs'] = is_array($editorGroupIDs) ? array_values($editorGroupIDs) : [];",
        "    $row['HouseState'] = $editorHouseState;",
        "    $row['Severity'] = $editorSeverity;",
        "    $row['BypassThrottle'] = $editorBypassThrottle;",
        "    $row['OutputResourceIDs'] = is_array($editorOutputIDs) ? array_values($editorOutputIDs) : [];",
        "}",
        "unset($row);",
        "IPS_SetProperty($id, 'GroupStateMappings', json_encode($rows));",
        "IPS_ApplyChanges($id);"
      ]
    },
    {
      "type": "Label",
      "caption": "Select a row in Rule Overview, load it into the editor, edit groups/outputs with multi-select, then apply it back."
    }
  ],
  "status": [
    {
      "code": 101,
      "icon": "inactive",
      "caption": "Creating instance"
    },
    {
      "code": 102,
      "icon": "active",
      "caption": "Instance is active"
    },
    {
      "code": 104,
      "icon": "inactive",
      "caption": "Instance is inactive"
    },
    {
      "code": 200,
      "icon": "error",
      "caption": "Module 1 read failed"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "No routing found for this Module 3 instance in imported Module 1 GroupDispatch"
    },
    {
      "code": 202,
      "icon": "active",
      "caption": "Module 1 configuration imported"
    },
    {
      "code": 203,
      "icon": "active",
      "caption": "Rows built from this Module 3 routing"
    }
  ]
}