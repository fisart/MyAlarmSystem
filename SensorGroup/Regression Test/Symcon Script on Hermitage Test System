function psm_now(): string
{
    return date('Y-m-d H:i:s');
}

function psm_sleep_ms(int $ms): void
{
    if ($ms > 0) {
        IPS_Sleep($ms);
    }
}

function psm_log(string $msg): void
{
    echo $msg . PHP_EOL;
}

function psm_safe_name(int $varId): string
{
    $name = @IPS_GetName($varId);
    return (is_string($name) && $name !== '') ? $name : (string) $varId;
}

function psm_write_value(int $varId, $value): array
{
    $before = GetValue($varId);
    SetValue($varId, $value);
    $after = GetValue($varId);

    return [
        'variable_id' => $varId,
        'label'       => psm_safe_name($varId),
        'before'      => $before,
        'requested'   => $value,
        'after'       => $after,
        'write_ok'    => ($after === $value)
    ];
}

function psm_get_state(int $module2Id): array
{
    if (!function_exists('PSM_GetSystemState')) {
        throw new RuntimeException('PSM_GetSystemState() is not available.');
    }

    $raw = PSM_GetSystemState($module2Id);

    if (is_array($raw)) {
        return $raw;
    }

    if (is_string($raw)) {
        $trim = trim($raw);
        if ($trim === '') {
            throw new RuntimeException('PSM_GetSystemState() returned empty string.');
        }

        $decoded = json_decode($trim, true);
        if (json_last_error() === JSON_ERROR_NONE && is_array($decoded)) {
            return $decoded;
        }

        throw new RuntimeException('PSM_GetSystemState() returned invalid JSON string.');
    }

    throw new RuntimeException('PSM_GetSystemState() returned unsupported type: ' . gettype($raw));
}

function psm_state_token(array $state): array
{
    return [
        'last_seen_event_epoch'      => $state['last_seen_event_epoch'] ?? null,
        'last_seen_event_seq'        => $state['last_seen_event_seq'] ?? null,
        'last_processed_event_epoch' => $state['last_processed_event_epoch'] ?? null,
        'last_processed_event_seq'   => $state['last_processed_event_seq'] ?? null,
        'last_token_missing'         => $state['last_token_missing'] ?? null
    ];
}

function psm_token_advanced(array $before, array $after): bool
{
    $pairs = [
        ['last_seen_event_seq', 'seq'],
        ['last_processed_event_seq', 'processed seq'],
        ['last_seen_event_epoch', 'epoch'],
        ['last_processed_event_epoch', 'processed epoch']
    ];

    foreach ($pairs as [$key, $label]) {
        if ($before[$key] !== null && $after[$key] !== null) {
            if ((int) $after[$key] > (int) $before[$key]) {
                return true;
            }
        }
    }

    return false;
}

function psm_contains_active_sensor(array $state, $needle): bool
{
    $active = $state['ActiveSensors'] ?? [];
    $needleStr = (string) $needle;

    foreach ($active as $entry) {
        if ((string) $entry === $needleStr) {
            return true;
        }
    }
    return false;
}

function psm_find_presence_row(array $state, string $groupName): ?array
{
    $map = $state['PresenceMap'] ?? [];
    foreach ($map as $row) {
        if (($row['GroupName'] ?? '') === $groupName) {
            return $row;
        }
    }
    return null;
}

function psm_add_assertion(array &$assertions, bool $ok, string $message, array $context = []): void
{
    $assertions[] = [
        'ok'      => $ok,
        'message' => $message,
        'context' => $context
    ];
}

function psm_assert_write_results(array $writes, array &$assertions): void
{
    foreach ($writes as $write) {
        psm_add_assertion(
            $assertions,
            (bool) $write['write_ok'],
            'Write confirmed for variable ' . $write['variable_id'],
            $write
        );
    }
}

function psm_reset_all_inputs(array $allInputIds): void
{
    global $RESET_GAP_MS, $RESET_SETTLE_MS;

    foreach ($allInputIds as $varId) {
        SetValue((int) $varId, false);
        psm_sleep_ms($RESET_GAP_MS);
    }

    psm_sleep_ms($RESET_SETTLE_MS);
}

// -----------------------------------------------------
// WAIT / STABILITY HELPERS
// -----------------------------------------------------

function psm_matches_wait_condition(array $state, array $waitFor): bool
{
    if (array_key_exists('StateID', $waitFor)) {
        if (($state['StateID'] ?? null) !== $waitFor['StateID']) {
            return false;
        }
    }

    if (array_key_exists('IsDelayActive', $waitFor)) {
        if (($state['IsDelayActive'] ?? null) !== $waitFor['IsDelayActive']) {
            return false;
        }
    }

    if (!empty($waitFor['active_sensors'])) {
        foreach ($waitFor['active_sensors'] as $sensorKey) {
            if (!psm_contains_active_sensor($state, $sensorKey)) {
                return false;
            }
        }
    }

    if (!empty($waitFor['not_active_sensors'])) {
        foreach ($waitFor['not_active_sensors'] as $sensorKey) {
            if (psm_contains_active_sensor($state, $sensorKey)) {
                return false;
            }
        }
    }

    if (!empty($waitFor['presence_map'])) {
        foreach ($waitFor['presence_map'] as $groupName => $rowExpect) {
            $row = psm_find_presence_row($state, $groupName);
            if ($row === null) {
                return false;
            }

            foreach ($rowExpect as $field => $value) {
                if (($row[$field] ?? null) !== $value) {
                    return false;
                }
            }
        }
    }

    return true;
}

function psm_wait_until_stable(int $module2Id, array $waitFor, int $timeoutMs, int $pollMs, int $stableHitsRequired): array
{
    $start = microtime(true);
    $lastState = psm_get_state($module2Id);
    $stableHits = 0;

    while (((microtime(true) - $start) * 1000) < $timeoutMs) {
        $lastState = psm_get_state($module2Id);

        if (psm_matches_wait_condition($lastState, $waitFor)) {
            $stableHits++;
            if ($stableHits >= $stableHitsRequired) {
                return [
                    'ok'          => true,
                    'state'       => $lastState,
                    'waited_ms'   => (int) round((microtime(true) - $start) * 1000),
                    'stable_hits' => $stableHits,
                    'wait_for'    => $waitFor
                ];
            }
        } else {
            $stableHits = 0;
        }

        IPS_Sleep($pollMs);
    }

    return [
        'ok'          => false,
        'state'       => $lastState,
        'waited_ms'   => (int) round((microtime(true) - $start) * 1000),
        'stable_hits' => $stableHits,
        'wait_for'    => $waitFor
    ];
}

