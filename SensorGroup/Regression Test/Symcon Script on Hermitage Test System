$startedAt = psm_now();
$scenarioPass = 0;
$scenarioFail = 0;
$failedItems = [];
$results = [];

psm_log('START FULL REGRESSION TEST | module2=' . $MODULE2_ID);

try {
    foreach ($SCENARIOS as $scenario) {
        $result = psm_run_scenario($MODULE2_ID, $scenario, $ALL_INPUT_IDS);
        $results[] = $result;

        if ($result['status'] === 'PASS') {
            $scenarioPass++;
            psm_log('PASS | ' . $result['id'] . ' | ' . $result['title']);
        } else {
            $scenarioFail++;
            psm_log('FAIL | ' . $result['id'] . ' | ' . $result['title']);

            foreach ($result['steps'] as $step) {
                if ($step['status'] !== 'PASS') {
                    foreach ($step['assertions'] as $assertion) {
                        if (!$assertion['ok']) {
                            $failedItems[] = [
                                'scenario_id'    => $result['id'],
                                'scenario_title' => $result['title'],
                                'step'           => $step['label'],
                                'message'        => $assertion['message']
                            ];
                        }
                    }
                }
            }
        }
    }
} catch (Throwable $e) {
    psm_log('FATAL ERROR: ' . $e->getMessage());
    psm_log($e->getTraceAsString());

    $scenarioFail++;
    $failedItems[] = [
        'scenario_id'    => 'FATAL',
        'scenario_title' => 'Unhandled exception',
        'step'           => 'runtime',
        'message'        => $e->getMessage()
    ];
}

$finishedAt = psm_now();

psm_log('--------------------------------------------------');
psm_log('SUMMARY | PASS=' . $scenarioPass . ' | FAIL=' . $scenarioFail);
psm_log('--------------------------------------------------');

if (count($failedItems) > 0) {
    psm_log('FAILED ASSERTIONS:');
    foreach ($failedItems as $item) {
        psm_log(
            '- ' . $item['scenario_id']
            . ' | ' . $item['scenario_title']
            . ' | ' . $item['step']
            . ' | ' . $item['message']
        );
    }
} else {
    psm_log('FAILED ASSERTIONS: none');
}

$report = [
    'test_script_version'      => $TEST_SCRIPT_VERSION,
    'scenario_matrix_version'  => $SCENARIO_MATRIX_VERSION,
    'expected_module2_version' => $EXPECTED_MODULE2_VERSION,
    'logic_profile'            => $LOGIC_PROFILE,
    'started_at'               => $startedAt,
    'finished_at'              => $finishedAt,
    'module2_id'               => $MODULE2_ID,
    'scenario_pass'            => $scenarioPass,
    'scenario_fail'            => $scenarioFail,
    'failed_assertions'        => $failedItems,
    'scenario_results'         => $results
];

$json = json_encode($report, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
if ($json === false) {
    throw new RuntimeException('json_encode failed.');
}

$filename = rtrim($REPORT_DIR, '/') . '/psm_full_regression_' . date('Ymd_His') . '.json';
$bytes = file_put_contents($filename, $json);
if ($bytes === false) {
    throw new RuntimeException('Could not write report file: ' . $filename);
}

psm_log('REPORT FILE: ' . $filename);
psm_log('BYTES WRITTEN: ' . $bytes);
psm_log('END FULL REGRESSION TEST');
