function psm_check_expected_state(array $expect, array $state, array $tokenBefore, array $tokenAfter, array &$assertions): void
{
    if (array_key_exists('StateID', $expect)) {
        psm_add_assertion(
            $assertions,
            (($state['StateID'] ?? null) === $expect['StateID']),
            'Expected StateID=' . $expect['StateID'] . ', got ' . json_encode($state['StateID'] ?? null)
        );
    }

    if (array_key_exists('IsDelayActive', $expect)) {
        psm_add_assertion(
            $assertions,
            (($state['IsDelayActive'] ?? null) === $expect['IsDelayActive']),
            'Expected IsDelayActive=' . json_encode($expect['IsDelayActive']) . ', got ' . json_encode($state['IsDelayActive'] ?? null)
        );
    }

    if (!empty($expect['active_sensors'])) {
        foreach ($expect['active_sensors'] as $sensorKey) {
            psm_add_assertion(
                $assertions,
                psm_contains_active_sensor($state, $sensorKey),
                'Expected active sensor present: ' . (string) $sensorKey
            );
        }
    }

    if (!empty($expect['not_active_sensors'])) {
        foreach ($expect['not_active_sensors'] as $sensorKey) {
            psm_add_assertion(
                $assertions,
                !psm_contains_active_sensor($state, $sensorKey),
                'Expected active sensor absent: ' . (string) $sensorKey
            );
        }
    }

    if (!empty($expect['presence_map'])) {
        foreach ($expect['presence_map'] as $groupName => $rowExpect) {
            $row = psm_find_presence_row($state, $groupName);

            psm_add_assertion(
                $assertions,
                $row !== null,
                'PresenceMap row exists for "' . $groupName . '"'
            );

            if ($row !== null) {
                foreach ($rowExpect as $field => $value) {
                    psm_add_assertion(
                        $assertions,
                        (($row[$field] ?? null) === $value),
                        'PresenceMap "' . $groupName . '" field "' . $field . '" expected ' . json_encode($value) . ', got ' . json_encode($row[$field] ?? null)
                    );
                }
            }
        }
    }

    if (!empty($expect['token_must_advance'])) {
        psm_add_assertion(
            $assertions,
            psm_token_advanced($tokenBefore, $tokenAfter),
            'Token must advance'
        );

        if (($tokenAfter['last_token_missing'] ?? null) !== null) {
            psm_add_assertion(
                $assertions,
                ((int) $tokenAfter['last_token_missing'] === 0),
                'last_token_missing must be 0, got ' . json_encode($tokenAfter['last_token_missing'])
            );
        }
    }
}

function psm_assert_step(array $writes, array $expect, array $state, array $tokenBefore, array $tokenAfter, ?array $waitResult = null): array
{
    $assertions = [];

    psm_assert_write_results($writes, $assertions);

    psm_add_assertion(
        $assertions,
        psm_token_advanced($tokenBefore, $tokenAfter),
        'Module 2 processed a newer snapshot/token'
    );

    if (($tokenAfter['last_token_missing'] ?? null) !== null) {
        psm_add_assertion(
            $assertions,
            ((int) $tokenAfter['last_token_missing'] === 0),
            'No missing token condition'
        );
    }

    if ($waitResult !== null) {
        psm_add_assertion(
            $assertions,
            (bool) ($waitResult['ok'] ?? false),
            'Stable wait condition reached',
            $waitResult
        );
    }

    psm_check_expected_state($expect, $state, $tokenBefore, $tokenAfter, $assertions);

    return $assertions;
}

function psm_status_from_assertions(array $assertions): string
{
    foreach ($assertions as $a) {
        if (!$a['ok']) {
            return 'FAIL';
        }
    }
    return 'PASS';
}

// -----------------------------------------------------
// STEP / SCENARIO EXECUTION
// -----------------------------------------------------

function psm_run_step(int $module2Id, array $step): array
{
    global $ACTION_GAP_MS, $SETTLE_MS, $DEFAULT_WAIT_TIMEOUT_MS, $DEFAULT_WAIT_POLL_MS, $DEFAULT_WAIT_STABLE_HITS, $FINAL_READBACK_SETTLE_MS;

    $tokenBefore = psm_state_token(psm_get_state($module2Id));

    $writes = [];
    foreach ($step['actions'] as $varId => $value) {
        $writes[] = psm_write_value((int) $varId, $value);
        psm_sleep_ms($ACTION_GAP_MS);
    }

    $waitResult = null;

    if (!empty($step['wait_for']) && is_array($step['wait_for'])) {
        $timeoutMs = (int) ($step['wait_for']['timeout_ms'] ?? $DEFAULT_WAIT_TIMEOUT_MS);
        $pollMs = (int) ($step['wait_for']['poll_ms'] ?? $DEFAULT_WAIT_POLL_MS);
        $stableHits = (int) ($step['wait_for']['stable_hits'] ?? $DEFAULT_WAIT_STABLE_HITS);

        $waitFor = $step['wait_for'];
        unset($waitFor['timeout_ms'], $waitFor['poll_ms'], $waitFor['stable_hits']);

        $waitResult = psm_wait_until_stable($module2Id, $waitFor, $timeoutMs, $pollMs, $stableHits);

        // Final reread after a short extra settle to avoid edge-of-transition snapshots.
        psm_sleep_ms($FINAL_READBACK_SETTLE_MS);
        $stateAfter = psm_get_state($module2Id);

        $waitResult['final_state_after_reread'] = $stateAfter;
        $waitResult['final_reread_settle_ms'] = $FINAL_READBACK_SETTLE_MS;
    } else {
        psm_sleep_ms($SETTLE_MS);
        $stateAfter = psm_get_state($module2Id);
    }

    $tokenAfter = psm_state_token($stateAfter);

    $assertions = psm_assert_step(
        $writes,
        $step['expect'] ?? [],
        $stateAfter,
        $tokenBefore,
        $tokenAfter,
        $waitResult
    );

    $status = psm_status_from_assertions($assertions);

    return [
        'label'        => $step['label'],
        'writes'       => $writes,
        'expect'       => $step['expect'] ?? [],
        'wait_for'     => $step['wait_for'] ?? null,
        'wait_result'  => $waitResult,
        'state'        => $stateAfter,
        'token_before' => $tokenBefore,
        'token_after'  => $tokenAfter,
        'assertions'   => $assertions,
        'status'       => $status
    ];
}

function psm_run_scenario(int $module2Id, array $scenario, array $allInputIds): array
{
    psm_reset_all_inputs($allInputIds);

    $result = [
        'id'       => $scenario['id'],
        'title'    => $scenario['title'],
        'kind'     => $scenario['kind'],
        'started'  => psm_now(),
        'steps'    => [],
        'status'   => 'PASS'
    ];

    foreach ($scenario['steps'] as $step) {
        $stepResult = psm_run_step($module2Id, $step);
        $result['steps'][] = $stepResult;

        if ($stepResult['status'] !== 'PASS') {
            $result['status'] = 'FAIL';
        }
    }

    $result['finished'] = psm_now();
    return $result;
}

